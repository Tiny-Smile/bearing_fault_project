    print(f"随机种子: 42")
    print("=" * 50)
```

## 2. 日志记录（训练过程要记下来）

### 简单的日志写法

```python
import os
from datetime import datetime

def 创建日志文件(实验名: str) -> str:
    """创建日志文件，返回文件路径"""
    # 创建日志文件夹
    log_dir = os.path.join(PROJECT_ROOT, "05_logs")
    os.makedirs(log_dir, exist_ok=True)
    
    # 文件名加上时间戳，避免重复
    时间 = datetime.now().strftime("%Y%m%d_%H%M%S")
    log_file = os.path.join(log_dir, f"{实验名}_{时间}.log")
    
    return log_file

def 写日志(日志文件: str, 内容: str):
    """写入日志内容"""
    with open(日志文件, 'a', encoding='utf-8') as f:
        时间 = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        f.write(f"[{时间}] {内容}\n")

# 用法
log_file = 创建日志文件("训练")
写日志(log_file, "开始训练...")
写日志(log_file, "Epoch 1/100, Loss: 0.25")
```

### 训练时记录的指标

```python
# 每个 epoch 结束后记录这些
写日志(log_file, f"Epoch {i}:")
写日志(log_file, f"  训练损失 = {train_loss:.4f}")
写日志(log_file, f"  验证准确率 = {val_acc:.4f}")
写日志(log_file, f"  学习率 = {lr:.6f}")
```

## 3. 保存结果

### 保存位置

```
项目根目录/
└── 06_results/           # 所有结果放这里
    ├── figures/          # 图片（png格式，300清晰度）
    ├── metrics/          # 指标数据（csv格式）
    └── report/            # 实验报告（md格式）
```

### 保存图片

```python
import matplotlib.pyplot as plt

def 保存图片(图片, 文件名: str):
    """保存图片到正确位置"""
    # 保存到 06_results/figures/
    save_dir = os.path.join(PROJECT_ROOT, "06_results", "figures")
    os.makedirs(save_dir, exist_ok=True)
    
    save_path = os.path.join(save_dir, 文件名)
    
    # dpi=300 表示高清，bbox_inches='tight' 裁掉白边
    plt.savefig(save_path, dpi=300, bbox_inches='tight')
    plt.close()  # 关掉图片释放内存
    
    print(f"图片已保存: {save_path}")
```

### 保存指标数据

```python
import csv

def 保存评估结果(结果字典: dict, 文件名: str):
    """保存评估结果到 CSV 文件"""
    save_dir = os.path.join(PROJECT_ROOT, "06_results", "metrics")
    os.makedirs(save_dir, exist_ok=True)
    
    save_path = os.path.join(save_dir, 文件名)
    
    with open(save_path, 'w', newline='', encoding='utf-8') as f:
        writer = csv.writer(f)
        writer.writerow(['指标', '值'])  # 写表头
        for 指标名, 指标值 in 结果字典.items():
            writer.writerow([指标名, 指标值])
    
    print(f"结果已保存: {save_path}")
```

## 4. 保存模型

### 保存整个模型

```python
import torch

def 保存模型(模型, 文件名: str, epoch: int):
    """保存训练好的模型"""
    save_dir = os.path.join(PROJECT_ROOT, "04_models_ckpt")
    os.makedirs(save_dir, exist_ok=True)
    
    save_path = os.path.join(save_dir, 文件名)
    
    torch.save({
        'epoch': epoch,
        'model_state_dict': 模型.state_dict(),
    }, save_path)
    
    print(f"模型已保存: {save_path}")
```

### 加载模型

```python
def 加载模型(模型, 文件名: str):
    """加载已保存的模型"""
    save_path = os.path.join(PROJECT_ROOT, "04_models_ckpt", 文件名)
    
    checkpoint = torch.load(save_path, map_location='cpu')
    模型.load_state_dict(checkpoint['model_state_dict'])
    
    return 模型
```

## 5. 评价指标

### 常用指标

| 指标 | 什么意思 | 越高越好还是越低越好 |
|------|----------|---------------------|
| 准确率 | 分类正确的比例 | 越高越好 |
| F1分数 | 综合考虑查准率和召回率 | 越高越好 |
| 混淆矩阵 | 看哪些类容易搞混 | 对角线越大越好 |

### 计算方法

```python
from sklearn.metrics import accuracy_score, f1_score, confusion_matrix

def 评估模型(真实标签, 预测标签):
    """评估模型并打印结果"""
    准确率 = accuracy_score(真实标签, 预测标签)
    F1 = f1_score(真实标签, 预测标签, average='macro')
    混淆 = confusion_matrix(真实标签, 预测标签)
    
    print("=" * 40)
    print("评估结果")
    print("=" * 40)
    print(f"准确率: {准确率:.4f} ({准确率*100:.2f}%)")
    print(f"F1分数: {F1:.4f}")
    print("混淆矩阵:")
    print(混淆)
    print("=" * 40)
    
    return {
        'accuracy': 准确率,
        'f1_score': F1,
        'confusion_matrix': 混淆.tolist()
    }
```

